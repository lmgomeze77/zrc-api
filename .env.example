# ZRC API â€” Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# Resend API key â€” get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Email where form submissions are sent
NOTIFY_EMAIL=info@zenithrisecapital.com

# Sender address (must match your verified Resend domain)
FROM_EMAIL=ZRC Platform <noreply@zenithrisecapital.com>

# Frontend URL for CORS
FRONTEND_URL=https://zenithrisecapital.com

# Port (Render sets this automatically)
PORT=3001
