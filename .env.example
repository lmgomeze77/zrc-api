# ═══════════════════════════════════════════════
# ZRC API — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Email where form submissions are sent
NOTIFY_EMAIL=info@zenrisecapital.com

# Sender address (must match your verified Resend domain)
FROM_EMAIL=ZRC Platform <noreply@zenrisecapital.com>

# Frontend URL for CORS
FRONTEND_URL=https://zenrisecapital.com

# Port (Render sets this automatically)
PORT=3001
